<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <title>GM Build Counts</title>
    <%- include('../partials/analytics'); %>
</head>
<body>
    <%- include('../partials/header'); %>
    <div class="custom-container">
        <div class="content">
            <div class="container-fluid">
                <h1 class="pt-4">GM Build Counts & Statistics Database</h1>
                <p class="lead">Production & Statistics extracted from Window Stickers with vehicle image generation through VIN based RPO codes.</p>
                <h2 class="bg-danger-subtle border border-danger-subtle text-danger-emphasis px-4 py-3 rounded position-relative fw-bold">GM's Window Sticker API was updated on April 23, 2026. All window stickers with creation dates prior to January 1, 2022 were purged from their servers.</h2>
                <h2 class="i-link"><a href="/vehicles"><i class="bi bi-car-front-fill me-1"></i>Vehicles</a></h2>
                <p>Select a specific model to view build counts and statistics. <span class="text-legacy">2019 only.</span></p>

                <div class="vehicle-selection-grid mb-4">
                    <h5 class="mt-3 mb-2" style="color: white; font-size: 0.9rem; letter-spacing: 1px;">CHEVROLET</h5>
                    <div class="row g-2">
                        <div class="col-6 col-md-4 col-lg-3">
                            <div class="row g-2">
                                <div class="col-12 i-link">
                                    <a href="/vehicles?model=CAMARO" class="model-btn w-100">CAMARO</a>
                                </div>
                                <div class="col-12 i-link">
                                    <a href="/vehicles?model=SILVERADO%20EV" class="model-btn w-100">SILVERADO EV</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-md-8 col-lg-9">
                            <div class="row g-2">
                                <div class="col-12 i-link">
                                    <a href="/vehicles?model=CORVETTE%20E-RAY&model=CORVETTE%20GRAND%20SPORT&model=CORVETTE%20STINGRAY&model=CORVETTE%20STINGRAY%20W%2F%20Z51&model=CORVETTE%20Z06&model=CORVETTE%20ZR1&model=CORVETTE%20ZR1X" class="model-btn w-100 featured-corvette-btn d-flex align-items-center justify-content-center">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 27 27" fill="currentColor" class="me-2">
                                            <path fill-rule="evenodd" stroke="currentColor" stroke-width="1px" 
                                                d="M1.533,1.500 C1.587,1.500 1.641,1.500 1.695,1.500 C1.933,1.847 2.370,2.135 2.707,2.389 C3.051,2.648 3.324,3.011 3.679,3.279 C3.974,3.501 4.194,3.865 4.489,4.087 C5.521,4.866 6.427,5.834 7.364,6.714 C7.396,8.529 8.303,9.080 9.348,9.867 C10.182,10.495 10.892,11.293 11.737,11.929 C12.176,12.258 12.545,12.683 12.993,13.020 C13.148,13.137 13.331,13.474 13.519,13.424 C14.035,13.249 14.801,12.275 15.260,11.929 C16.101,11.294 16.823,10.490 17.649,9.867 C18.730,9.054 19.563,8.562 19.634,6.714 C20.058,6.475 20.308,5.989 20.686,5.704 C21.800,4.864 22.688,3.756 23.804,2.915 C24.186,2.627 25.003,1.559 25.465,1.500 C25.465,1.527 25.465,1.554 25.465,1.581 C25.589,1.797 25.348,2.868 25.343,3.238 C25.333,4.042 25.224,5.283 25.060,6.027 C24.922,6.649 25.063,7.234 24.898,7.806 C24.529,9.083 23.289,10.017 22.549,10.999 C22.433,11.153 22.205,11.280 22.104,11.444 C21.957,11.682 22.063,12.125 21.982,12.414 C21.856,12.865 21.625,13.284 21.375,13.627 C21.156,13.926 20.788,14.141 20.565,14.435 C19.530,15.799 18.156,16.870 17.123,18.235 C16.815,18.641 16.232,18.988 15.949,19.407 C15.595,19.929 15.557,21.009 15.341,21.670 C15.224,22.028 15.100,22.541 14.896,22.843 C14.731,23.086 14.462,23.294 14.288,23.530 C14.101,23.783 13.762,24.434 13.438,24.500 C13.143,24.021 12.726,23.584 12.385,23.126 C12.251,22.945 12.029,22.785 11.940,22.560 C11.657,21.845 11.526,21.023 11.292,20.296 C11.192,19.985 11.217,19.644 11.049,19.407 C10.750,18.985 10.228,18.687 9.915,18.275 C8.891,16.926 7.536,15.867 6.514,14.516 C6.269,14.192 5.862,13.955 5.623,13.627 C5.346,13.247 5.102,12.765 4.975,12.252 C4.902,11.958 5.031,11.625 4.894,11.403 C4.745,11.269 4.597,11.134 4.448,10.999 C3.981,10.382 3.457,9.840 2.991,9.221 C2.734,8.880 2.402,8.599 2.221,8.170 C2.050,7.764 2.130,7.336 2.019,6.836 C1.816,5.929 1.896,4.794 1.695,3.885 C1.695,3.737 1.695,3.588 1.695,3.440 C1.607,3.037 1.427,1.841 1.533,1.500 Z"/>
                                        </svg>
                                        ALL CORVETTE MODELS
                                    </a>
                                </div>
                                <% 
                                const corvetteVariants = [
                                    'CORVETTE STINGRAY', 'CORVETTE STINGRAY W/ Z51', 'CORVETTE GRAND SPORT', 
                                    'CORVETTE E-RAY', 'CORVETTE Z06', 'CORVETTE ZR1', 'CORVETTE ZR1X'
                                ];
                                corvetteVariants.forEach(model => { 
                                    const isLegacy = (model === 'CORVETTE STINGRAY W/ Z51' || model === 'CORVETTE GRAND SPORT');
                                %>
                                    <div class="col-12 col-md-6 col-lg-4 i-link">
                                        <a href="/vehicles?model=<%= encodeURIComponent(model) %>" 
                                        class="model-btn w-100 vette-variant-btn <%= isLegacy ? 'text-legacy' : '' %>">
                                        <%= model %>
                                        </a>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>

                    <h5 class="mt-4 mb-2" style="color: white; font-size: 0.9rem; letter-spacing: 1px;">GMC</h5>
                    <div class="row g-2">
                        <div class="col-6 col-md-4 col-lg-3">
                            <div class="row g-2">
                                <div class="col-12 i-link">
                                    <a href="/vehicles?model=SIERRA%20EV" class="model-btn w-100">SIERRA EV</a>
                                </div>
                                </div>
                        </div>

                        <div class="col-6 col-md-8 col-lg-9">
                            <div class="row g-2">
                                <div class="col-12 i-link">
                                    <a href="/vehicles?model=HUMMER%20EV%20PICKUP&model=HUMMER%20EV%20SUV" class="model-btn w-100 featured-gmc-btn">
                                        <i class="bi bi-lightning-fill me-2"></i>ALL HUMMER EV MODELS
                                    </a>
                                </div>
                                
                                <% 
                                const hummerVariants = ['HUMMER EV PICKUP', 'HUMMER EV SUV'];
                                hummerVariants.forEach(model => { %>
                                    <div class="col-12 col-md-6 i-link">
                                        <a href="/vehicles?model=<%= encodeURIComponent(model) %>" class="model-btn w-100 hummer-variant-btn"><%= model %></a>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>

                    <h5 class="mt-4 mb-2" style="color: white; font-size: 0.9rem; letter-spacing: 1px;">CADILLAC</h5>
                    <div class="row g-2">
                        <div class="col-6 col-md-4 col-lg-3">
                            <div class="row g-2">
                                <% 
                                const standardCaddy = ['CELESTIQ', 'CT4', 'CT5', 'CT6'];
                                standardCaddy.forEach(model => { 
                                %>
                                    <div class="col-12 i-link">
                                        <a href="/vehicles?model=<%= encodeURIComponent(model) %>" class="model-btn w-100">
                                            <%= model %>
                                        </a>
                                    </div>
                                <% }); %>
                            </div>
                        </div>

                        <div class="col-6 col-md-8 col-lg-9">
                            <div class="row g-2">
                                <div class="col-12 i-link">
                                    <a href="/vehicles?model=ESCALADE&model=ESCALADE%20ESV&model=ESCALADE%20IQ" 
                                    class="model-btn w-100 featured-caddy-btn d-flex align-items-center justify-content-center">
                                        <i class="bi bi-gem me-2"></i> ALL ESCALADE MODELS
                                    </a>
                                </div>

                                <% 
                                const escaladeVariants = ['ESCALADE', 'ESCALADE ESV', 'ESCALADE IQ'];
                                escaladeVariants.forEach(model => { 
                                %>
                                    <div class="col-12 col-md-6 col-lg-4 i-link">
                                        <a href="/vehicles?model=<%= encodeURIComponent(model) %>" 
                                        class="model-btn w-100 caddy-variant-btn">
                                            <%= model %>
                                        </a>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                </div>
                <p class="mb-5">
                    Search for RPO codes to filter at the top of the table.<br>
                    VIN and MSRP column headers will sort in either direction.<br>
                    Highlighted VINs are Pre-Production vehicles with RPO code <span class="highlight">OAR</span>.<br>
                    Select a row to view detailed vehicle information including RPO codes, vehicle images, and more.<br>
                    &nbsp;- Window Stickers are only available typically after May 16, 2019. The majority of 2019 are unavailable, with a few early 2020 not appearing.
                </p>

                <div class="row g-4">
                    <div class="col-12 col-sm-6 col-xl-3">
                        <h2 class="i-link"><a href="/stats"><i class="bi bi-list-ol me-1"></i>Stats</a></h2>
                        <p>Statistics and charts on vehicle data including: Exterior Paint, Engines, and Production.</p>
                    </div>
                    
                    <div class="col-12 col-sm-6 col-xl-3">
                        <h2 class="i-link"><a href="/wheels"><i class="bi bi-fan me-1"></i>Wheels</a></h2>
                        <p>Images & Descriptions of wheels for a given model.</p>
                    </div>
                    
                    <div class="col-12 col-sm-6 col-xl-3">
                        <h2 class="i-link"><a href="/rpos"><i class="bi bi-database-fill me-1"></i>RPOs</a></h2>
                        <p>Images & Descriptions of RPOs for a given model. Only RPOs with official images are listed.</p>
                    </div>
                    
                    <div class="col-12 col-sm-6 col-xl-3">
                        <h2 class="i-link"><a href="/about"><i class="bi bi-info-lg me-1"></i>About</a></h2>
                        <p>Progress & last window sticker creation date for each model/year.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/footer'); %>
</body>
</html>
