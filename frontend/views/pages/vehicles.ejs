<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>    
    <title>Vehicles</title>
    <%- include('../partials/analytics'); %>
</head>
<body>
    <%- include('../partials/header'); %>
    <div class="custom-container">
        <div class="row" style="padding-top: 20px;">
            <!-- Filters -->
            <div class="col-md-6">
                <div id="filterToggle" class="d-inline-flex align-items-center" style="cursor: pointer;">
                    <h4 class="mb-0">Filter</h4>
                    <i class="bi bi-chevron-down fs-9 ms-2" id="filterIcon"></i>
                </div>
                <div id="filterContent" class="collapse">
                    <form id="filterForm">
                        <% 
                            const chevroletStatic = ['CAMARO', 'SILVERADO EV'];
                            const gmcStatic = ['SIERRA EV'];
                            const cadillacStatic = ['CT4', 'CT5', 'CT6', 'ESCALADE', 'ESCALADE ESV', 'ESCALADE IQ', 'CELESTIQ'];
                            const buickStatic = [];

                            const brandGroups = {
                                'Chevrolet': models.filter(m => m.startsWith('CORVETTE') || chevroletStatic.includes(m)),
                                'GMC': models.filter(m => m.startsWith('HUMMER') || gmcStatic.includes(m)),
                                'Cadillac': models.filter(m => cadillacStatic.includes(m)),
                                'Buick': models.filter(m => buickStatic.includes(m))
                            };

                            const categorizedList = Object.values(brandGroups).flat();
                            const otherModels = models.filter(m => !categorizedList.includes(m));
                            if (otherModels.length > 0) {
                                brandGroups['Other Brands'] = otherModels;
                            }
                        %>

                        <% Object.entries(brandGroups).forEach(function([brand, availableModels]) { 
                            if (availableModels.length > 0) { %>
                                <div class="brand-group mt-3">
                                    <h6 class="border-bottom pb-1 text-uppercase small fw-bold text-light"><%= brand %></h6>
                                    <% availableModels.forEach(function(model) { %>
                                        <div class="form-check d-flex align-items-center">
                                            <input 
                                                class="form-check-input mt-0" 
                                                type="checkbox" 
                                                name ="model" id="model_<%= model %>" 
                                                value="<%= model %>"
                                                <%= selectedModels.includes(model) ? 'checked' : '' %>
                                            >
                                            <label class="form-check-label ms-2" for="model_<%= model %>">
                                                <%= model %>
                                            </label>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } 
                        }) %>

                        <button type="submit" class="btn btn-primary mt-3 w-100">Apply Filters</button>
                        <% if (selectedModels.length > 0 || selectedRPO || selectedTrim || selectedEngine || selectedTrans || selectedDrivetrain || selectedYear || selectedBody || selectedColor || selectedCountry || limit != 100 || selectedOrder) { %>
                            <button type="button" id="clearFilters" class="btn btn-secondary mt-2 w-100">Clear All</button>
                        <% } %>
                    </form>
                </div>
            </div>
            <!-- RPO Search -->
            <div class="col-md-4 mt-2 position-relative">
                <input type="text" id="rpoSearchInput" class="form-control" placeholder="Search RPOs..." />
                <ul id="rpoResults" class="list-group mt-2"></ul>
                <div id="selectedRPOs" class="selected-rpos mt-1"></div>
            </div>
            <div class="stats d-flex justify-content-between align-items-end">
                <p id="totalCount">
                    Retrieved <%= totalItems.toLocaleString() %> vehicles in <%= elapsedTime.toLocaleString() %> seconds
                </p>
                <div class="dropdown-container">
                    <select id="limitSelect" class="form-select small-dropdown">
                        <option value="100" <% if (limit === 100) { %>selected<% } %>>100</option>
                        <option value="150" <% if (limit === 150) { %>selected<% } %>>150</option>
                        <option value="200" <% if (limit === 200) { %>selected<% } %>>200</option>
                        <option value="250" <% if (limit === 250) { %>selected<% } %>>250</option>
                    </select>
                </div>
            </div>
            <%
            function buildQuery(params) {
                const query = [];
                for (const [key, value] of Object.entries(params)) {
                    if (Array.isArray(value)) {
                        value.forEach(v => query.push(`${key}=${encodeURIComponent(v)}`));
                    } else if (value !== undefined && value !== null && value !== '') {
                        query.push(`${key}=${encodeURIComponent(value)}`);
                    }
                }

                const pageQuery = query.find(q => q.startsWith('page='));
                const filtered = query.filter(q => !q.startsWith('page='));
                if (pageQuery) filtered.push(pageQuery);

                return filtered.join('&');
            }

            const baseQuery = {
                limit,
                model: selectedModels.length ? selectedModels : undefined,
                rpo: selectedRPO,
                trim: selectedTrim,
                engine: selectedEngine,
                trans: selectedTrans,
                drivetrain: selectedDrivetrain,
                year: selectedYear,
                body: selectedBody,
                color: selectedColor,
                country: selectedCountry,
                order: selectedOrder
            };
            %>
            <% if (selectedYear === '2019') { %>
                <div style="color: #cc6666; margin-bottom: 10px;">
                    Data available from May 17, 2019 onward
                </div>
            <% } %>
            <%- include('../partials/pagination', { currentPage, totalPages, baseQuery, buildQuery }) %>
            <!-- Vehicles Table -->
            <div id="top-scroll-wrapper">
                <div id="top-scroll"></div>
            </div>
            <div class="table-responsive" id="bottom-scroll-wrapper">
                <% if (vehicle_data && vehicle_data.length) { %>
                <table class="table-veh table-hover border border shadow" id="allTable">
                    <thead>
                        <tr>
                            <th scope="col" id="vinHeader" class="sortable" onclick="toggleVINOrder()" style="cursor: pointer;">
                                VIN
                                <i class="bi bi-chevron-down" id="vinIcon" style="display: none;"></i>
                            </th>
                            <th scope="col">
                                <div class="dropdown-container">
                                    <select id="yearSelect" class="form-select small-dropdown <%= selectedYear ? 'active-filter' : '' %>">
                                        <option value="">Year</option>
                                        <% years.forEach(function(year) { %>
                                            <option value="<%= year %>" <% if (selectedYear === year.toString()) { %>selected<% } %>><%= year %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            </th>
                            <th scope="col">Model</th>
                            <th scope="col">
                                <div class="dropdown-container">
                                    <select id="bodySelect" class="form-select small-dropdown <%= selectedBody ? 'active-filter' : '' %>">
                                        <option value="">Body</option>
                                        <% bodys.forEach(function(body) { %>
                                            <option value="<%= body %>" <% if (selectedBody === body.toString()) { %>selected<% } %>><%= body %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            </th>
                            <th scope="col">
                                <div class="dropdown-container">
                                    <select id="trimSelect" class="form-select small-dropdown <%= selectedTrim ? 'active-filter' : '' %>">
                                        <option value="">Trim</option>
                                        <% trim.forEach(function(trim) { %>
                                            <option value="<%= trim %>" <% if (selectedTrim === trim) { %>selected<% } %>><%= trim %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            </th>
                            <th scope="col">
                                <div class="dropdown-container">
                                    <select id="engineSelect" class="form-select small-dropdown <%= selectedEngine ? 'active-filter' : '' %>">
                                        <option value="">Engine</option>
                                        <% engine.forEach(function(engine) { %>
                                            <option value="<%= engine.name %>" <% if (selectedEngine === engine.name) { %>selected<% } %>><%= engine.rpo ? engine.rpo + ' - ' : '' %><%= engine.name %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            </th>
                            <th scope="col">
                                <div class="dropdown-container">
                                    <select id="transSelect" class="form-select small-dropdown <%= selectedTrans ? 'active-filter' : '' %>">
                                        <option value="">Trans.</option>
                                        <% trans.forEach(function(trans) { %>
                                            <option value="<%= trans %>" <% if (selectedTrans === trans) { %>selected<% } %>><%= trans %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            </th>
                            <th scope="col">
                                <div class="dropdown-container">
                                    <select id="drivetrainSelect" class="form-select small-dropdown <%= selectedDrivetrain ? 'active-filter' : '' %>">
                                        <option value="">Drivetrain</option>
                                        <% if (typeof drivetrains !== 'undefined') { %>
                                            <% drivetrains.forEach(function(dt) { %>
                                                <option value="<%= dt %>" <% if (selectedDrivetrain === dt) { %>selected<% } %>><%= dt %></option>
                                            <% }) %>
                                        <% } %>
                                    </select>
                                </div>
                            </th>
                            <th scope="col">
                                <div class="dropdown-container">
                                    <select id="colorSelect" class="form-select small-dropdown <%= selectedColor ? 'active-filter' : '' %>">
                                        <option value="">Exterior Color</option>
                                        <% colors.forEach(function(color) { %>
                                            <option value="<%= color %>" <% if (selectedColor === color) { %>selected<% } %>><%= color %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            </th>
                            <th scope="col" id="msrpHeader" class="sortable" onclick="toggleMSRPOrder()" style="cursor: pointer;">
                                MSRP
                                <i class="bi bi-chevron-down" id="msrpIcon" style="display: none;"></i>
                            </th>
                            <th scope="col">
                                <div class="dropdown-container">
                                    <% const rpo = Array.isArray(selectedRPO) ? selectedRPO[0] : selectedRPO; %>
                                    <select id="rpoSelect" class="form-select small-dropdown <%= rpo ? 'active-filter' : '' %>">
                                        <option value="" <% if (!rpo) { %>selected<% } %>>Package/Option</option>
                                        <optgroup label="Camaro">
                                            <option value="Z4B" <% if (rpo === 'Z4B') { %>selected<% } %>>Collector's Edition</option>
                                            <option value="ZL4B" <% if (rpo === 'ZL4B') { %>selected<% } %>>ZL1 Collector's Edition</option>
                                            <option value="X56" <% if (rpo === 'X56') { %>selected<% } %>>Garage 56 Special Edition</option>
                                            <option value="A1Z" <% if (rpo === 'A1Z') { %>selected<% } %>>ZL1 1LE Extreme Track Performance Package</option>
                                            <option value="A1Y" <% if (rpo === 'A1Y') { %>selected<% } %>>SS 1LE Track Performance Package</option>
                                            <option value="A1X" <% if (rpo === 'A1X') { %>selected<% } %>>LT 1LE Track Performance Package</option>
                                            <option value="H40" <% if (rpo === 'H40') { %>selected<% } %>>Hendrick Motorsports 40th Anniversary Edition</option>
                                            <option value="PEH" <% if (rpo === 'PEH') { %>selected<% } %>>Hertz / Hendrick Motorsports Edition</option>
                                            <option value="Z4Z" <% if (rpo === 'Z4Z') { %>selected<% } %>>Indy 500 Pace Car</option>
                                            <option value="WBL" <% if (rpo === 'WBL') { %>selected<% } %>>Redline Edition</option>
                                            <option value="B2E" <% if (rpo === 'B2E') { %>selected<% } %>>Shock and Steel Edition</option>
                                        </optgroup>
                                        <optgroup label="Corvette">
                                            <option value="ZCR" <% if (rpo === 'ZCR') { %>selected<% } %>>IMSA GTLM Championship C8.R Edition</option>
                                            <option value="ZTK" <% if (rpo === 'ZTK') { %>selected<% } %>>ZTK Track Performance Package</option>
                                            <option value="Z07" <% if (rpo === 'Z07') { %>selected<% } %>>Z07 Performance Package</option>
                                            <option value="Z51" <% if (rpo === 'Z51') { %>selected<% } %>>Z51 Performance Package</option>
                                            <option value="FEB" <% if (rpo === 'FEB') { %>selected<% } %>>Z52 Sport Performance Package</option>
                                            <option value="FEY" <% if (rpo === 'FEY') { %>selected<% } %>>Z52 Track Performance Package</option>
                                            <option value="Z25" <% if (rpo === 'Z25') { %>selected<% } %>>Grand Sport Launch Edition</option>
                                            <option value="Y70" <% if (rpo === 'Y70') { %>selected<% } %>>Stingray 70th Anniversary Edition</option>
                                            <option value="USA" <% if (rpo === 'USA') { %>selected<% } %>>Stars & Steel Limited Edition</option>
                                            <option value="ZRA" <% if (rpo === 'ZRA') { %>selected<% } %>>Quail Silver Limited Edition</option>
                                        </optgroup>
                                        <optgroup label="CT4-V Blackwing">
                                            <option value="ZLE" <% if (rpo === 'ZLE') { %>selected<% } %>>Watkins Glen IMSA Edition</option>
                                            <option value="ZLD" <% if (rpo === 'ZLD') { %>selected<% } %>>Sebring IMSA Edition</option>
                                            <option value="ZLG" <% if (rpo === 'ZLG') { %>selected<% } %>>Road Atlanta IMSA Edition</option>
                                            <option value="ZLK" <% if (rpo === 'ZLK') { %>selected<% } %>>Arrival Edition</option>
                                            <option value="ZLJ" <% if (rpo === 'ZLJ') { %>selected<% } %>>Impact Edition</option>
                                            <option value="ZLR" <% if (rpo === 'ZLR') { %>selected<% } %>>Elevation Edition</option>
                                            <option value="ZLZ4" <% if (rpo === 'ZLZ4') { %>selected<% } %>>Petit Pataud Special Edition</option>
                                        </optgroup>
                                        <optgroup label="CT5-V Blackwing">
                                            <option value="ABQ" <% if (rpo === 'ABQ') { %>selected<% } %>>120th Anniversary Edition</option>
                                            <option value="ZLT" <% if (rpo === 'ZLT') { %>selected<% } %>>20th Anniversary Edition</option>
                                            <option value="ZLZ5" <% if (rpo === 'ZLZ5') { %>selected<% } %>>Le Monstre Special Edition</option>
                                            <option value="V8V" <% if (rpo === 'V8V') { %>selected<% } %>>Precision Package</option>
                                            <option value="PCK1" <% if (rpo === 'PCK1') { %>selected<% } %>>Deep Ocean Appearance Package</option>
                                            <!-- <option value="" <% if (rpo === '') { %>selected<% } %>>F1 Collector's Edition</option> -->    
                                        </optgroup>
                                        <optgroup label="Hummer EV">
                                            <option value="Z6X" <% if (rpo === 'Z6X') { %>selected<% } %>>Extreme Off-Road Package</option>
                                            <option value="WFP" <% if (rpo === 'WFP') { %>selected<% } %>>Omega Edition</option>
                                        </optgroup>
                                        <option value="OAR" <% if (rpo === 'OAR') { %>selected<% } %>>Pre-Production Vehicle</option>
                                    </select>
                                </div>
                            </th>
                            <th scope="col">
                                <div class="dropdown-container">
                                    <select id="countrySelect" class="form-select small-dropdown <%= selectedCountry ? 'active-filter' : '' %>">
                                        <option value="">Country</option>
                                        <option value="USA" <% if (selectedCountry === 'USA') { %>selected<% } %>>USA</option>
                                        <option value="CAN" <% if (selectedCountry === 'CAN') { %>selected<% } %>>Canada</option>
                                        <% if (colors.includes("PANTHER BLACK MATTE")) { %>
                                            <option value="MEX" <% if (selectedCountry === 'MEX') { %>selected<% } %>>Mexico</option>
                                        <% } %>
                                    </select>
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <% vehicle_data.forEach(function(data) { %>
                            <tr style="cursor: pointer;" onmousedown="handleMouseDown(event);" data-url="/search?vin=<%= data.vin %>">
                                <td scope="row" style="text-align: left;" class="<%= data.special_desc && data.special_desc.includes('Pre-Production Vehicle') ? 'highlight' : '' %>">
                                                    <%= data.vin.slice(0, 9) %><strong><%= data.vin.slice(9) %></strong>
                                                 </td>
                                 <td scope="row"><%= data.modelYear %></td>
                                <td scope="row"><%= data.model %></td>
                                <td scope="row"><%= data.body %></td>
                                <td scope="row"><%= data.trim %></td>
                                <td scope="row"><%= data.engine_type %></td>
                                <td scope="row"><%= data.transmission_type %></td>
                                <td scope="row"><%= data.drivetrain_type %></td>
                                <td scope="row" style="text-align: left; align-items: center;">
                                    <% 
                                        // Determine the RPO code for the image source
                                        let imageRpoCode = colorMap[data.color_name];

                                        if (data.color_name === 'BLADE SILVER METALLIC' && Number(data.modelYear) >= 2026) {
                                            imageRpoCode = 'GKA';
                                        }

                                        // Use the determined RPO code, falling back to 'default' if the code is undefined/null
                                        const finalImageSrcRPO = imageRpoCode || 'default';
                                    %>
                                    <img 
                                        id="sample" 
                                        src="../../img/extColors/<%= finalImageSrcRPO %>.webp" 
                                        alt="Color Code: <%= finalImageSrcRPO %>" 
                                        width="20" 
                                        height="20"
                                        onerror="this.onerror=null; this.src='../../img/extColors/default.webp';"
                                    >
                                    <%= data.color_name %>
                                </td>
                                <td scope="row" class="accounting-format">
                                    <% if (data.msrp == 0) { %>
                                        <span></span>
                                        <span>N/A</span>
                                    <% } else { %>
                                        <span>$</span>
                                        <span><%= data.msrp %></span>
                                    <% } %>
                                </td>
                                <td scope="row"><%= data.special_desc %></td>
                                <td scope="row">
                                    <% if (data.country == "USA") { %>
                                        <img src="../../img/flags/usa_flag.webp" alt="USA Flag" width="20">
                                    <% } else if (data.country == "CANADA") { %>
                                        <img src="../../img/flags/canada_flag.webp" alt="Canada Flag" width="20">
                                    <% } else { %>
                                        <img src="../../img/flags/mexico_flag.webp" alt="Mexico Flag" width="20">
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <%- include('../partials/pagination', { currentPage, totalPages, baseQuery, buildQuery }) %>
            <% } else { %>
                <div class="response-container" style="padding: 40px 0;">
                    <div class="response" role="status">
                        <p>No results found for the current filters.</p>
                        <div style="margin-top: 12px; display:flex; gap:10px; justify-content:center;">
                            <button type="button" class="btn btn-outline-light" onclick="history.back()">Go Back</button>
                            <button type="button" class="btn btn-secondary" id="clearFiltersBtn" onclick="window.location.href='/vehicles'">Clear Filters</button>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
    <%- include('../partials/footer'); %>
    <script>
        let startX;
        let selectedOrder = '';

        const intColor = <%- JSON.stringify(intColor) %>;
        const camaroRpo = <%- JSON.stringify(camaroRpo) %>;
        const corvetteRpo = <%- JSON.stringify(corvetteRpo) %>;
        const escaladeRpo = <%- JSON.stringify(escaladeRpo) %>;
        const escaladeiqRpo = <%- JSON.stringify(escaladeiqRpo) %>;
        const ct4Rpo = <%- JSON.stringify(ct4Rpo) %>;
        const ct4vRpo = <%- JSON.stringify(ct4vRpo) %>;
        const ct5Rpo = <%- JSON.stringify(ct5Rpo) %>;
        const ct5vRpo = <%- JSON.stringify(ct5vRpo) %>;
        const hummerRpo = <%- JSON.stringify(hummerRpo) %>;
        const hummersuvRpo = <%- JSON.stringify(hummersuvRpo) %>;

        function buildQueryString(params) {
            const queryStrings = Object.entries(params)
                .filter(([key, value]) => value)
                .map(([key, value]) => `${encodeURIComponent(key)}=${encodeURIComponent(value)}`)
                .join('&');
            return queryStrings;
        }

        function toggleOrder(type, ascValue, descValue, iconId) {
            selectedOrder = selectedOrder === ascValue ? descValue : ascValue;
            document.getElementById(iconId).className = selectedOrder === ascValue ? 'bi bi-chevron-up' : 'bi bi-chevron-down';
            const params = new URLSearchParams(window.location.search);
            params.set('order', selectedOrder);
            window.location.search = params.toString();
        }

        function toggleMSRPOrder() {
            toggleOrder("msrp", "DESC", "ASC", "msrpIcon");
        }

        function toggleVINOrder() {
            toggleOrder("vin", "vinASC", "vinDESC", "vinIcon");
        }

        function handleMouseDown(event) {
            startX = event.clientX;
        }

        function handleRowClick(url, event) {
            const distance = Math.abs(event.clientX - startX);
            if (distance > 5) {
                return;
            }

            if (typeof url !== 'string') {
                return;
            }

            const trimmedUrl = url.trim();
            try {
                const parsedUrl = new URL(trimmedUrl, window.location.origin);
                if (parsedUrl.origin !== window.location.origin) {
                    return;
                }

                const safePathname = parsedUrl.pathname;

                if (!safePathname.startsWith('/')) {
                    return;
                }

                // Allow only expected internal vehicles routes.
                if (!/^\/(vehicles|search)(\/[A-Za-z0-9._~!$&'()*+,;=:@%-]*)?$/.test(safePathname)) {
                    return;
                }

                // Navigate only to the validated internal pathname.
                window.location.assign(safePathname + parsedUrl.search);
            } catch (e) {
                return;
            }
        }

        function addSelectListener(selectId, paramName) {
            const selectElement = document.getElementById(selectId);
            if (!selectElement) return;

            selectElement.addEventListener('change', function(event) {
                const value = event.target.value;
                const url = new URL(window.location.href);
                if (value) {
                    url.searchParams.set(paramName, value);
                } else {
                    url.searchParams.delete(paramName);
                }
                url.searchParams.set('page', 1);
                window.location.href = url.toString();
            });
        }

        function updateIcons(selectedOrder) {
            const vinIcon = document.getElementById('vinIcon');
            const msrpIcon = document.getElementById('msrpIcon');

            function setIcon(iconElement, iconType, condition) {
                iconElement.className = condition ? `bi bi-chevron-${iconType}` : '';
                iconElement.style.display = condition ? 'inline' : 'none';
            }
            setIcon(msrpIcon, selectedOrder === 'ASC' ? 'up' : 'down', selectedOrder === 'ASC' || selectedOrder === 'DESC');
            setIcon(vinIcon, selectedOrder === 'vinASC' ? 'up' : 'down', selectedOrder === 'vinASC' || selectedOrder === 'vinDESC');
        }

        document.addEventListener('DOMContentLoaded', function() {
            const rpoDataSets = [
                { data: intColor, label: 'Interior Color' },
                { data: camaroRpo, label: 'Camaro' },
                { data: corvetteRpo, label: 'Corvette' },
                { data: escaladeRpo, label: 'Escalade' },
                { data: escaladeiqRpo, label: 'Escalade IQ' },
                { data: ct4Rpo, label: 'CT4' },
                { data: ct4vRpo, label: 'CT4-V' },
                { data: ct5Rpo, label: 'CT5' },
                { data: ct5vRpo, label: 'CT5-V' },
                { data: hummerRpo, label: 'Hummer EV Pickup' },
                { data: hummersuvRpo, label: 'Hummer EV SUV' }
            ];

            const rawMasterMap = {};
            rpoDataSets.forEach(set => {
                Object.entries(set.data).forEach(([code, description]) => {
                    if (!description || description.trim() === "") return;

                    const cleanDesc = description.trim();

                    if (!rawMasterMap[code]) {
                        rawMasterMap[code] = {};
                    }
                    if (!rawMasterMap[code][cleanDesc]) {
                        rawMasterMap[code][cleanDesc] = new Set();
                    }

                    rawMasterMap[code][cleanDesc].add(set.label);
                });
            });

            const rpoDescriptions = {};
            Object.entries(rawMasterMap).forEach(([code, descGroup]) => {
                rpoDescriptions[code] = Object.entries(descGroup).map(([desc, labelsSet]) => {
                    const labelsArray = Array.from(labelsSet);
                    return `${desc} - ${labelsArray.join(', ')}`;
                });
            });

            const rpoSearchInput = document.getElementById('rpoSearchInput');
            const rpoResults = document.getElementById('rpoResults');

            window.renderSelectedRPOs = function() {
                const container = document.getElementById('selectedRPOs');
                container.innerHTML = '';
                const url = new URL(window.location.href);
                const rpoParam = url.searchParams.get('rpo');
                if (!rpoParam) return;
                const rpos = rpoParam.split(',');

                rpos.forEach(code => {
                    const tag = document.createElement('button');
                    tag.type = 'button';
                    tag.className = 'rpo-tag';

                    const descArray = rpoDescriptions[code] || [];

                    const content = document.createElement('span');
                    content.className = 'rpo-tag-content';
                    content.style.display = 'inline-flex';
                    content.style.alignItems = 'center';
                    content.style.gap = '6px';

                    const strong = document.createElement('strong');
                    strong.textContent = code;
                    content.appendChild(strong);
                    content.appendChild(document.createTextNode(':\u00A0'));

                    if (descArray.length > 0) {
                        const descStack = document.createElement('span');
                        descStack.className = 'rpo-desc-stack';
                        descStack.style.display = 'inline-flex';
                        descStack.style.flexDirection = 'column';
                        descStack.style.verticalAlign = 'middle';
                        descStack.style.textAlign = 'left';

                        descArray.forEach((desc, index) => {
                            const item = document.createElement('span');
                            item.className = 'rpo-desc-item';
                            item.style.display = 'block';
                            item.style.lineHeight = '1.3';
                            const trailingComma = index < descArray.length - 1 ? ',' : '';
                            item.textContent = `${desc}${trailingComma}`;
                            descStack.appendChild(item);
                        });

                        content.appendChild(descStack);
                    } else {
                        const noDesc = document.createElement('span');
                        noDesc.style.color = 'gray';
                        noDesc.style.fontStyle = 'italic';
                        noDesc.textContent = 'No description available';
                        content.appendChild(noDesc);
                    }

                    content.appendChild(document.createTextNode('\u00A0×'));
                    tag.appendChild(content);

                    tag.addEventListener('click', () => {
                        const newRpos = rpos.filter(r => r !== code);
                        const url = new URL(window.location.href);
                        if (newRpos.length) {
                            url.searchParams.set('rpo', newRpos.join(','));
                        } else {
                            url.searchParams.delete('rpo');
                        }
                        url.searchParams.set('page', 1);
                        window.location.href = url.toString();
                    });

                    container.appendChild(tag);
                });
            }

            renderSelectedRPOs();

            rpoSearchInput.addEventListener('input', function() {
                const query = rpoSearchInput.value.toUpperCase().trim();
                rpoResults.innerHTML = '';

                if (query.length > 1) {
                    Object.entries(rpoDescriptions).filter(([rpo, descArray]) => {
                        return rpo.includes(query) || descArray.some(d => d.toLowerCase().includes(query.toLowerCase()));
                    }).forEach(([rpo, descArray]) => {
                        const li = document.createElement('li');
                        li.classList.add('list-group-item');
                        li.style.cursor = 'pointer';

                        const highlightedRpo = rpo.replace(new RegExp(query, 'gi'), match => `<span class="highlight">${match}</span>`);
                        const highlightedDescriptions = descArray.map(desc => {
                            return desc.replace(new RegExp(query, 'gi'), match => `<span class="highlight">${match}</span>`);
                        });

                        li.innerHTML = `<strong>${highlightedRpo}</strong>:&nbsp; <span class="small text-muted">${highlightedDescriptions.join(' | ')}</span>`;
                        
                        li.addEventListener('click', () => {
                            const url = new URL(window.location.href);
                            const currentRPO = url.searchParams.get('rpo');
                            let newRPO;

                            if (currentRPO) {
                                const rpoSet = new Set(currentRPO.split(','));
                                rpoSet.add(rpo);
                                newRPO = Array.from(rpoSet).join(',');
                            } else {
                                newRPO = rpo;
                            }

                            url.searchParams.set('rpo', newRPO);
                            window.location.href = url.toString();
                        });

                        rpoResults.appendChild(li);
                    });
                }
            });

            const filterToggle = document.getElementById('filterToggle');
            const filterContent = document.getElementById('filterContent');
            const filterIcon = document.getElementById('filterIcon');
            const filterForm = document.getElementById('filterForm');
            const limitSelect = document.getElementById('limitSelect');
            const currentOrder = new URLSearchParams(window.location.search).get('order');
            selectedOrder = currentOrder;
            updateIcons(selectedOrder);

            // SCROLL SYNC (rAF Throttle)
            (function() {
                const topWrapper = document.getElementById('top-scroll-wrapper');
                const bottomWrapper = document.getElementById('bottom-scroll-wrapper');
                const topInner = document.getElementById('top-scroll');
                const tableEl = document.querySelector('.table-veh');

                if (!topWrapper || !topInner || !bottomWrapper || !tableEl) return;
                
                let resizeTimer;
                let isTicking = false;
                let sourceWrapper = null; 

                function updateTopInnerWidth() {
                    const width = tableEl.scrollWidth; 
                    if (width && topInner.style.width !== width + 'px') {
                        topInner.style.width = width + 'px';
                    }
                }

                function syncScroll(source, target) {
                    sourceWrapper = source;
                    
                    if (!isTicking) {
                        window.requestAnimationFrame(() => {
                            const targetWrapper = sourceWrapper === topWrapper ? bottomWrapper : topWrapper;
                            targetWrapper.scrollLeft = sourceWrapper.scrollLeft;
                            
                            isTicking = false;
                            sourceWrapper = null;
                        });
                        isTicking = true;
                    }
                }
                topWrapper.addEventListener('scroll', () => syncScroll(topWrapper, bottomWrapper), { passive: true });
                bottomWrapper.addEventListener('scroll', () => syncScroll(bottomWrapper, topWrapper), { passive: true });

                function debouncedResizeUpdate() {
                    clearTimeout(resizeTimer);
                    resizeTimer = setTimeout(updateTopInnerWidth, 50);
                }

                requestAnimationFrame(updateTopInnerWidth);
                setTimeout(updateTopInnerWidth, 200); 
                window.addEventListener('resize', debouncedResizeUpdate); 
            })();

            filterToggle.addEventListener('click', function() {
                if (filterContent.classList.contains('show')) {
                    filterContent.classList.remove('show');
                    filterIcon.classList.remove('rotate');
                } else {
                    filterContent.classList.add('show');
                    filterIcon.classList.add('rotate');
                }
            });

            const clearFiltersButton = document.getElementById('clearFilters');
            if (clearFiltersButton) {
                clearFiltersButton.addEventListener('click', function() {
                    window.location.href = '/vehicles';
                });
            }

            const rpoSelectElement = document.getElementById('rpoSelect');
            if (rpoSelectElement) {
                rpoSelectElement.addEventListener('change', function(event) {
                    const value = event.target.value;
                    const url = new URL(window.location.href);
                    if (value) {
                        url.searchParams.set('rpo', value);
                    } else {
                        url.searchParams.delete('rpo');
                    }
                    url.searchParams.set('page', 1);
                    window.location.href = url.toString();
                });
            }
            addSelectListener('yearSelect', 'year');
            addSelectListener('bodySelect', 'body');
            addSelectListener('trimSelect', 'trim');
            addSelectListener('engineSelect', 'engine');
            addSelectListener('transSelect', 'trans');
            addSelectListener('drivetrainSelect', 'drivetrain');
            addSelectListener('colorSelect', 'color');
            addSelectListener('countrySelect', 'country');
            addSelectListener('limitSelect', 'limit');

            filterForm.addEventListener('submit', function(event) {
                event.preventDefault();

                const params = new URLSearchParams();

                const currentUrlParams = new URLSearchParams(window.location.search);
                if (currentUrlParams.has('rpo')) {
                    params.set('rpo', currentUrlParams.get('rpo'));
                }

                const checkboxes = filterForm.querySelectorAll('input[type="checkbox"]');
                checkboxes.forEach(cb => {
                    if (cb.checked) params.append('model', cb.value);
                });

                const addIfPresent = (id, paramName) => {
                    const el = document.getElementById(id);
                    if (el && el.value) {
                        params.set(paramName, el.value);
                    } else if (!el && currentUrlParams.has(paramName)) {
                        params.set(paramName, currentUrlParams.get(paramName));
                    }
                };

                addIfPresent('yearSelect', 'year');
                addIfPresent('bodySelect', 'body');
                addIfPresent('trimSelect', 'trim');
                addIfPresent('engineSelect', 'engine');
                addIfPresent('transSelect', 'trans');
                addIfPresent('drivetrainSelect', 'drivetrain');
                addIfPresent('colorSelect', 'color');
                addIfPresent('countrySelect', 'country');
                addIfPresent('limitSelect', 'limit');
                
                if (selectedOrder) params.set('order', selectedOrder);

                params.set('page', 1);

                window.location.href = `/vehicles?${params.toString()}`;
            });

            document.querySelectorAll('#allTable tbody tr').forEach(row => {
                const url = row.getAttribute('data-url');
                row.addEventListener('mousedown', handleMouseDown);
                row.addEventListener('click', (event) => handleRowClick(url, event));
            });
        });
    </script>
</body>
</html>
