<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
    <title>About</title>
    <%- include('../partials/analytics'); %>
</head>
<body>
    <%- include('../partials/header'); %>
    <div class="custom-container about-page">
        <div class="content">
            <div class="container-fluid">                
                <style>
                    .table-veh th, .table-veh td {
                        text-align: center;
                        vertical-align: middle;
                        font-size: 0.7rem;
                        padding: 8px 4px;
                    }
                    .table-veh th:first-child, .table-veh td:first-child {
                        text-align: left;
                        font-weight: bold;
                    }

                    .table-secondary-tag {
                        color: white;
                        text-align: left;
                        font-weight: bold;
                        background-color: #696969;
                        font-size: 0.8rem !important;
                        padding: 3px !important;
                    }

                    /* Clickable Cells */
                    .table-veh th.clickable-header,
                    .table-veh td.clickable-model,
                    .table-veh td[class*="green"],
                    .table-veh td[class*="yellow"] {
                        cursor: pointer !important;
                    }

                    /* Hover Effects */
                    .table-veh th.clickable-header:hover,
                    .table-veh td.clickable-model:hover,
                    .table-veh td[class*="green"]:hover,
                    .table-veh td[class*="yellow"]:hover {
                        filter: brightness(0.9);
                        background-color: rgba(0,0,0,0.05);
                    }

                    /* Base Colors */
                    .cell-green { background-color: #28a745 !important; color: white; }
                    .cell-yellow { background-color: #ffc107 !important; color: black; }
                    .cell-na { background-color: #5e5e5e !important; color: #6c757d; }
                    .cell-pattern-gray-dense {
                        background-image: repeating-linear-gradient(135deg, #adb5bd 0, #adb5bd 1px, transparent 1px, transparent 2.5px) !important;
                        background-size: 2.5px 2.5px !important;
                    }

                    /* Split Styles: Crossed Only (2019 w/ no progress) */
                    .cell-split65-crossed-only {
                        background: repeating-linear-gradient(135deg, #adb5bd 0, #adb5bd 1px, transparent 1px, transparent 2.5px) !important;
                        -webkit-mask-image: linear-gradient(to right, black 65%, transparent 65%);
                        mask-image: linear-gradient(to right, black 65%, transparent 65%);
                    }

                    /* Split Styles: 65% Yellow/Crossed (2019 in progress) */
                    .cell-split65-yellow-crossed {
                        background-image: 
                            linear-gradient(#ffc107, #ffc107),
                            repeating-linear-gradient(135deg, #adb5bd 0, #adb5bd 1px, transparent 1px, transparent 2.5px) !important;
                        background-size: 35% 100%, 65% 100% !important;
                        background-position: right top, left top !important;
                        background-repeat: no-repeat !important;
                    }

                    /* Split Styles: 65% Green/Crossed (2019 completed) */
                    .cell-split65-green-crossed {
                        background-image: 
                            linear-gradient(#28a745, #28a745),
                            repeating-linear-gradient(135deg, #adb5bd 0, #adb5bd 1px, transparent 1px, transparent 2.5px) !important;
                        background-size: 35% 100%, 65% 100% !important;
                        background-position: right top, left top !important;
                        background-repeat: no-repeat !important;
                    }

                    /* Split Styles: 65% Crossed/NA (2019 N/A) */
                    .cell-split65-crossed-na {
                        background-image: 
                            linear-gradient(#5e5e5e, #5e5e5e),
                            repeating-linear-gradient(135deg, #adb5bd 0, #adb5bd 1px, transparent 1px, transparent 2.5px) !important;
                        background-size: 35% 100%, 65% 100% !important;
                        background-position: right top, left top !important;
                        background-repeat: no-repeat !important;
                    }

                    /* Split Styles: Crossed Only (2020 w/ no progress) */
                    .cell-split5-crossed-only {
                        background: repeating-linear-gradient(135deg, #adb5bd 0, #adb5bd 1px, transparent 1px, transparent 2.5px) !important;
                        -webkit-mask-image: linear-gradient(to right, black 5%, transparent 5%);
                        mask-image: linear-gradient(to right, black 5%, transparent 5%);
                    }

                    /* Split Styles: 5% Green/Crossed (2020 completed) */
                    .cell-split5-green-crossed {
                        background-image: 
                            linear-gradient(#28a745, #28a745),
                            repeating-linear-gradient(135deg, #adb5bd 0, #adb5bd 1px, transparent 1px, transparent 2.5px) !important;
                        background-size: 95% 100%, 5% 100% !important;
                        background-position: right top, left top !important;
                        background-repeat: no-repeat !important;
                    }

                    /* Split Styles: 5% Yellow/Crossed (2020 in progress) */
                    .cell-split5-yellow-crossed {
                        background-image: 
                            linear-gradient(#ffc107, #ffc107),
                            repeating-linear-gradient(135deg, #adb5bd 0, #adb5bd 1px, transparent 1px, transparent 2.5px) !important;
                        background-size: 95% 100%, 5% 100% !important;
                        background-position: right top, left top !important;
                        background-repeat: no-repeat !important;
                    }
                    
                    /* Split Styles: 5% Crossed/NA (Used 2020 N/A) */
                    .cell-split5-crossed-na {
                        background-image: 
                            linear-gradient(#5e5e5e, #5e5e5e),
                            repeating-linear-gradient(135deg, #adb5bd 0, #adb5bd 1px, transparent 1px, transparent 2.5px) !important;
                        background-size: 95% 100%, 5% 100% !important;
                        background-position: right top, left top !important;
                        background-repeat: no-repeat !important;
                    }

                    .legend-container { display: flex; align-items: center; padding: 5px 0 0 0; }
                    .legend-item { display: flex; align-items: center; }
                    .legend-box { display: inline-block; width: 15px; height: 15px; margin-right: 5px; border-radius: 3px; border: 1px solid #dee2e6; }
                    .legend-label { font-size: 0.8rem; font-weight: 500; color: #ffffff; }
                </style>

                <div class="legend-container d-flex mb-1">
                    <div class="legend-item me-4">
                        <span class="legend-box cell-green"></span>
                        <span class="legend-label">Complete</span>
                    </div>
                    <div class="legend-item me-4">
                        <span class="legend-box cell-yellow"></span>
                        <span class="legend-label">In Progress</span>
                    </div>
                    <div class="legend-item me-4">
                        <span class="legend-box cell-na"></span>
                        <span class="legend-label">N/A</span>
                    </div>
                    <div class="legend-item">
                        <span class="legend-box cell-pattern-gray-dense"></span>
                        <span class="legend-label">Unavailable*</span>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table-veh table-hover border shadow table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Model</th>
                                <th>2019</th>
                                <th>2020</th>
                                <th>2021</th>
                                <th>2022</th>
                                <th>2023</th>
                                <th>2024</th>
                                <th>2025</th>
                                <th>2026</th>
                                <th>2027</th>
                                <th>Last Updated</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="table-secondary">
                                <td colspan="11" class="table-secondary-tag">Chevrolet</td>
                            </tr>
                            <tr search-model="CAMARO" data-model="CAMARO">
                                <td>Camaro</td>
                                <td class="cell-split65-green-crossed"></td>
                                <td class="cell-split5-green-crossed"></td>
                                <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-green"></td>
                                <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-na"></td> <td></td>
                            </tr>
                            <tr search-model="CORVETTE" data-model="CORVETTE" data-multi-model="true">
                                <td>Corvette</td>
                                <td class="cell-split65-green-crossed"></td>
                                <td class="cell-split5-green-crossed"></td>
                                <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-yellow"></td> <td></td> <td></td>
                            </tr>
                            <tr search-model="SILVERADO EV" data-model="SILVERADO_EV">
                                <td>Silverado EV</td>
                                <td class="cell-split65-crossed-na"></td>
                                <td class="cell-split5-crossed-na"></td>
                                <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-green"></td> <td class="cell-yellow"></td> <td></td> <td></td> <td></td>
                            </tr>
                            <tr class="table-secondary">
                                <td colspan="11" class="table-secondary-tag">Cadillac</td>
                            </tr>
                            <tr search-model="CT4" data-model="CT4">
                                <td>CT4</td>
                                <td class="cell-split65-crossed-na"></td> <td class="cell-split5-green-crossed"></td>
                                <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-yellow"></td> <td></td> <td class="cell-na"></td> <td></td>
                            </tr>
                            <tr search-model="CT5" data-model="CT5">
                                <td>CT5</td>
                                <td class="cell-split65-crossed-na"></td> <td class="cell-split5-green-crossed"></td>
                                <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-yellow"></td> <td></td> <td></td> <td></td>
                            </tr>
                            <tr search-model="CT6" data-model="CT6">
                                <td>CT6</td>
                                <td class="cell-split65-green-crossed"></td>
                                <td class="cell-split5-green-crossed"></td>
                                <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-na"></td> <td></td>
                            </tr>
                            <tr search-model="ESCALADE" data-model="ESCALADE">
                                <td>Escalade</td>
                                <td class="cell-split65-crossed-only"></td>
                                <td class="cell-split5-crossed-only"></td> <td></td> <td></td> <td></td> <td></td> <td class="cell-yellow"></td> <td></td> <td></td> <td></td>
                            </tr>
                            <tr search-model="ESCALADE IQ" data-model="ESCALADE_IQ">
                                <td>Escalade IQ</td>
                                <td class="cell-split65-crossed-na"></td>
                                <td class="cell-split5-crossed-na"></td>
                                <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-yellow"></td> <td></td> <td></td> <td></td>
                            </tr>
                            <tr class="table-secondary">
                                <td colspan="11" class="table-secondary-tag">GMC</td>
                            </tr>
                            <tr search-model="HUMMER EV" data-model="HUMMER_EV" data-multi-model="true">
                                <td>Hummer EV</td>
                                <td class="cell-split65-crossed-na"></td>
                                <td class="cell-split5-crossed-na"></td>
                                <td class="cell-na"></td> <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-green"></td> <td class="cell-yellow"></td> <td></td> <td></td> <td></td>
                            </tr>
                            <tr search-model="SIERRA EV" data-model="SIERRA_EV">
                                <td>Sierra EV</td>
                                <td class="cell-split65-crossed-na"></td>
                                <td class="cell-split5-crossed-na"></td>
                                <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-na"></td> <td class="cell-green"></td> <td class="cell-yellow"></td> <td></td> <td></td> <td></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <p style="font-size: 0.65rem; margin-top: 0.5rem;">*Window stickers were uploaded starting mid-May 2019, making data incomplete for most of 2019/early 2020 model years.</p>
            </div>
        </div>
    </div>
    <%- include('../partials/footer'); %>
    <script>
        const stats = <%- JSON.stringify(stats) %>;

        document.addEventListener('DOMContentLoaded', function() {
            const table = document.querySelector('.table-veh');
            const tbodyRows = Array.from(table.querySelectorAll('tbody tr:not(.table-secondary)'));
            const headers = table.querySelectorAll('thead th');
            const headerTexts = Array.from(headers).map(th => th.innerText.trim());

            tbodyRows.forEach(row => {
                const hasData = !!row.querySelector('td[class*="green"], td[class*="yellow"]');
                const model = row.getAttribute('data-model');
                if (hasData) {
                    row.cells[0].classList.add('clickable-model');
                }
                if (model && stats[model]) {
                    row.lastElementChild.innerText = stats[model];
                }
            });

            for (let colIndex = 1; colIndex <= 9; colIndex++) {
                let colHasData = false;
                for (let row of tbodyRows) {
                    const cell = row.cells[colIndex];
                    if (cell && (cell.className.includes('green') || cell.className.includes('yellow'))) {
                        colHasData = true;
                        break;
                    }
                }
                if (colHasData) {
                    headers[colIndex].classList.add('clickable-header');
                }
            }

            table.addEventListener('click', function(e) {
                const cell = e.target.closest('td, th');
                const row = e.target.closest('tr');
                if (!cell) return;

                const isHeader = cell.tagName === 'TH';
                const isFirstColumn = cell.cellIndex === 0;
                const className = cell.className;
                const year = headerTexts[cell.cellIndex];

                const isStatusCell = className.includes('green') || className.includes('yellow');
                const isExcluded = cell.cellIndex === 10 || cell.hasAttribute('colspan');

                if (isHeader && !cell.classList.contains('clickable-header')) return;
                if (isFirstColumn && !cell.classList.contains('clickable-model')) return;

                if (!isHeader && !isFirstColumn && !isStatusCell) return;
                if (isExcluded) return;

                if (isHeader) {
                    if (/^\d{4}$/.test(year)) window.location.href = `/vehicles?year=${year}`;
                    return;
                }

                const model = row.getAttribute('search-model');
                const isMulti = row.getAttribute('data-multi-model') === 'true';
                let params = [];

                if (model === "CORVETTE" && isMulti) {
                    if (year === "2019") {
                        params.push('model=CORVETTE+GRAND+SPORT', 'model=CORVETTE+STINGRAY', 'model=CORVETTE+STINGRAY+W%2F+Z51', 'model=CORVETTE+Z06', 'model=CORVETTE+ZR1');
                    } else {
                        params.push('model=CORVETTE+E-RAY', 'model=CORVETTE+STINGRAY', 'model=CORVETTE+Z06', 'model=CORVETTE+ZR1', 'model=CORVETTE+ZR1X');
                    }
                } 
                else if (model === "HUMMER EV" && isMulti) {
                    params.push('model=HUMMER+EV+PICKUP', 'model=HUMMER+EV+SUV');
                } 
                else if (model) {
                    params.push(`model=${encodeURIComponent(model)}`);
                }

                if (!isFirstColumn && /^\d{4}$/.test(year)) {
                    params.push(`year=${year}`);
                }

                if (params.length > 0) {
                    window.location.href = '/vehicles?' + params.join('&');
                }
            });
        });
    </script>
</body>
</html>
